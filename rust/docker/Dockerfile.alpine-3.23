# Alpine 3.23 build image for rust-photoacoustic (multi-arch: amd64, arm64)

FROM sctg/rust-photoacoustic-static-deps:latest AS deps
FROM sctg/rust-photoacoustic-static-python:latest AS python
FROM alpine:3.23 AS builder

ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

ARG GIT_COMMIT_HASH_SHORT=unknown
ARG GIT_COMMIT_HASH_FULL=unknown
ARG GIT_COMMIT_DATE=unknown
ARG VERSION=0.0.0
ARG PYTHON_VERSION=3.13.13
ARG PYTHON_SHORT_VERSION=3.13
ARG TARGETPLATFORM=linux/amd64

ENV GIT_COMMIT_HASH_SHORT=${GIT_COMMIT_HASH_SHORT}
ENV GIT_COMMIT_HASH_FULL=${GIT_COMMIT_HASH_FULL}
ENV GIT_COMMIT_DATE=${GIT_COMMIT_DATE}
ENV VERSION=${VERSION}

# Map TARGETPLATFORM to Rust target triple
RUN case "${TARGETPLATFORM}" in \
    "linux/amd64") echo "x86_64-unknown-linux-musl" > /tmp/rust_target.txt ;; \
    "linux/arm64") echo "aarch64-unknown-linux-musl" > /tmp/rust_target.txt ;; \
    *) echo "x86_64-unknown-linux-musl" > /tmp/rust_target.txt ;; \
    esac && \
    cat /tmp/rust_target.txt

RUN apk update && apk add --no-cache \
    alpine-sdk \
    bash \
    curl \
    git \
    nodejs \
    npm \
    pkgconf \
    musl-dev \
    cmake \
    linux-headers \
    expat-dev expat-static \
    ca-certificates \
    && rm -rf /var/cache/apk/*

COPY --from=deps /usr/local/lib /usr/local/lib
COPY --from=deps /usr/local/include /usr/local/include
COPY --from=deps /usr/local/lib/pkgconfig /usr/local/lib/pkgconfig
COPY --from=python /usr/local/lib /usr/local/lib
COPY --from=python /usr/local/include /usr/local/include
COPY --from=python /usr/local/lib/pkgconfig /usr/local/lib/pkgconfig
COPY --from=python /Python-${PYTHON_VERSION}/pyo3-config.txt /Python-${PYTHON_VERSION}/pyo3-config.txt
COPY --from=python /usr/local/lib/python${PYTHON_SHORT_VERSION} /usr/local/lib/python${PYTHON_SHORT_VERSION}
COPY --from=python /usr/local/bin/python${PYTHON_SHORT_VERSION} /usr/local/bin/python3
COPY --from=python /usr/local/bin/pip /usr/local/bin/pip

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.91.1
RUN rustup target add x86_64-unknown-linux-musl && rustup target add aarch64-unknown-linux-musl

# Set Cargo build target based on TARGETPLATFORM
ENV RUST_TARGET_FILE=/tmp/rust_target.txt
RUN export RUST_TARGET=$(cat ${RUST_TARGET_FILE}) && \
    echo "Using Rust target: ${RUST_TARGET}"

ENV OPENSSL_DIR=/usr/local \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:$PKG_CONFIG_PATH \
    LD_LIBRARY_PATH=/usr/local/lib:/usr/lib:$LD_LIBRARY_PATH \
    LIBRDKAFKA_SYS_USE_PKG_CONFIG=1 \
    RDKAFKA_SYS_USE_PKG_CONFIG=1 \
    PKG_CONFIG_ALLOW_CROSS=1 \
    RDKAFKA_SYS_STATIC=1 \
    RDKAFKA_SYS_STATIC_LIBRDKAFKA=1 \
    CFLAGS="-I/usr/local/include -I/usr/local/include/python${PYTHON_SHORT_VERSION}" \
    LDFLAGS="-L/usr/local/lib -L/usr/local/lib64 -L/usr/lib -Wl,--start-group -lpython${PYTHON_SHORT_VERSION} -lssl -lcrypto -lffi -lz -lbz2 -llzma -luuid -lintl -lexpat -lmimalloc -ltermcap -lhistory -lasound -lreadline -Wl,--end-group" \
    RUSTFLAGS="-C link-arg=-L/usr/local/lib -C link-arg=-L/usr/local/lib64 -C link-arg=-Wl,--start-group -C link-arg=-lpython${PYTHON_SHORT_VERSION} -C link-arg=-lssl -C link-arg=-lcrypto -C link-arg=-lintl -C link-arg=-lffi -C link-arg=-lz -C link-arg=-lbz2 -C link-arg=-llzma -C link-arg=-luuid -C link-arg=-lexpat -C link-arg=-lmimalloc -C link-arg=-ltermcap -C link-arg=-lhistory -C link-arg=-lasound -C link-arg=-lreadline -C link-arg=-lpthread -C link-arg=-lc -C link-arg=/usr/local/lib/libbz_internal_error.a -C link-arg=-Wl,--end-group" \
    PYO3_PYTHON=/usr/local/bin/python3 \
    PYO3_PYTHON_VERSION=$PYTHON_SHORT_VERSION \
    PYTHON_SYS_EXECUTABLE=/usr/local/bin/python${PYTHON_SHORT_VERSION} \
    PYO3_NO_PYTHON=0 \
    PYO3_CONFIG_FILE=/Python-${PYTHON_VERSION}/pyo3-config.txt \
    PYTHON_LDFLAGS="-L/usr/local/lib -Wl,--start-group -lpython${PYTHON_SHORT_VERSION} -lssl -lcrypto -lintl -lffi -lz -lbz2 -llzma -luuid -lexpat -ltermcap -lhistory -lasound -lreadline -Wl,--end-group"

# Build web console
COPY web/ /workspace/web/
COPY rust/config.example.yaml /workspace/rust/config.yaml
RUN cd /workspace/web && npm install && npm run build

# Copy docs and rust source
COPY docs/ /workspace/docs/
WORKDIR /workspace/rust
COPY rust/ /workspace/rust/

RUN cd docker/remove-auto-init && \
    export RUST_TARGET=$(cat /tmp/rust_target.txt) && \
    cargo build --release --target ${RUST_TARGET} && \
    mkdir -p /usr/local/bin && \
    cp target/${RUST_TARGET}/release/remove-auto-init /usr/local/bin/remove-auto-init
WORKDIR /workspace/rust
RUN /usr/local/bin/remove-auto-init Cargo.toml
RUN export RUST_TARGET=$(cat /tmp/rust_target.txt) && \
    cargo build --release --target ${RUST_TARGET}
RUN export RUST_TARGET=$(cat /tmp/rust_target.txt) && \
    strip target/${RUST_TARGET}/release/rust_photoacoustic && \
    strip target/${RUST_TARGET}/release/create_token && \
    strip target/${RUST_TARGET}/release/analyze_spectrum && \
    strip target/${RUST_TARGET}/release/debug_config && \
    strip target/${RUST_TARGET}/release/differential && \
    strip target/${RUST_TARGET}/release/filters && \
    strip target/${RUST_TARGET}/release/modbus_client && \
    strip target/${RUST_TARGET}/release/noise_generator && \
    strip target/${RUST_TARGET}/release/pid_tuner && \
    strip target/${RUST_TARGET}/release/redis_viewer && \
    strip target/${RUST_TARGET}/release/rs256keygen && \
    strip target/${RUST_TARGET}/release/standalone && \
    cp target/${RUST_TARGET}/release/rust_photoacoustic /usr/local/bin/rust_photoacoustic && \
    cp target/${RUST_TARGET}/release/create_token /usr/local/bin/create_token && \
    cp target/${RUST_TARGET}/release/analyze_spectrum /usr/local/bin/analyze_spectrum && \
    cp target/${RUST_TARGET}/release/debug_config /usr/local/bin/debug_config && \
    cp target/${RUST_TARGET}/release/differential /usr/local/bin/differential && \
    cp target/${RUST_TARGET}/release/filters /usr/local/bin/filters && \
    cp target/${RUST_TARGET}/release/modbus_client /usr/local/bin/modbus_client && \
    cp target/${RUST_TARGET}/release/noise_generator /usr/local/bin/noise_generator && \
    cp target/${RUST_TARGET}/release/pid_tuner /usr/local/bin/pid_tuner && \
    cp target/${RUST_TARGET}/release/redis_viewer /usr/local/bin/redis_viewer && \
    cp target/${RUST_TARGET}/release/rs256keygen /usr/local/bin/rs256keygen && \
    cp target/${RUST_TARGET}/release/standalone /usr/local/bin/standalone

# # Build APK package (requires non-root user in abuild group)
