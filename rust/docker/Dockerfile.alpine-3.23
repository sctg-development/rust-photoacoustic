# USER builder
# RUN cd /workspace/abuild && abuild-keygen -a -n -q && abuild -r
# USER root
# RUN find /home/builder/packages -name 'lasersmart-*.apk' -exec cp {} /packages/ \;
# RUN find /root/packages -name 'lasersmart-*.apk' -exec cp {} /packages/ \;

# Runtime image
FROM alpine:3.23 AS runtime
ARG PYTHON_VERSION=3.13.13
ARG PYTHON_SHORT_VERSION=3.13
RUN apk add --no-cache ca-certificates libexpat

# Copy Python runtime files (libs, binaries, pip)
COPY --from=builder /usr/local/bin/python3 /usr/local/bin/python3
COPY --from=builder /usr/local/bin/pip /usr/local/bin/pip
COPY --from=builder /usr/local/lib/python${PYTHON_SHORT_VERSION} /usr/local/lib/python${PYTHON_SHORT_VERSION}

# Create symlinks for compatibility
RUN ln -sf /usr/local/bin/python3 /usr/local/bin/python && \
    ln -sf /usr/local/bin/python3 /usr/local/bin/python${PYTHON_SHORT_VERSION} && \
    ln -sf /usr/local/bin/pip /usr/local/bin/pip3

# Copy compiled binaries
COPY --from=builder /usr/local/bin/rust_photoacoustic /usr/local/bin/rust_photoacoustic
COPY --from=builder /usr/local/bin/create_token /usr/local/bin/create_token
COPY --from=builder /usr/local/bin/analyze_spectrum /usr/local/bin/analyze_spectrum
COPY --from=builder /usr/local/bin/debug_config /usr/local/bin/debug_config
COPY --from=builder /usr/local/bin/differential /usr/local/bin/differential
COPY --from=builder /usr/local/bin/filters /usr/local/bin/filters
COPY --from=builder /usr/local/bin/modbus_client /usr/local/bin/modbus_client
COPY --from=builder /usr/local/bin/noise_generator /usr/local/bin/noise_generator
COPY --from=builder /usr/local/bin/pid_tuner /usr/local/bin/pid_tuner
COPY --from=builder /usr/local/bin/redis_viewer /usr/local/bin/redis_viewer
COPY --from=builder /usr/local/bin/rs256keygen /usr/local/bin/rs256keygen
COPY --from=builder /usr/local/bin/standalone /usr/local/bin/standalone

CMD ["/usr/local/bin/rust_photoacoustic"]
